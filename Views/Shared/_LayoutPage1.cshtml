    <div id="aiChatWidget">
        <button id="chatToggleBtn" class="chat-widget-button" onclick="toggleChatbox()">
            <i class="fas fa-robot"></i>
            <span class="chat-badge">AI</span>
        </button>

        <div id="chatboxPopup" class="chatbox-popup" style="display: none;">
            <div class="chatbox-header">
                <div class="chatbox-header-content">
                    <i class="fas fa-robot"></i>
                    <div>
                        <h4>Trợ Lý AI</h4>
                        <p>ALPHA BOOK</p>
                    </div>
                </div>
                <button onclick="toggleChatbox()" class="chatbox-close-btn">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="chatbox-body">
                <div id="chatboxMessages" class="chatbox-messages">
                    <div class="chatbox-welcome">
                        <i class="fas fa-book-reader"></i>
                        <h5>Xin chào! 👋</h5>
                        <p>Tôi là trợ lý AI của ALPHA BOOK. Tôi có thể giúp gì cho bạn?</p>
                    </div>

                    <div class="chatbox-suggestions">
                        <button class="suggestion-btn" onclick="sendQuickMessage('Gợi ý sách hay')">
                            📚 Gợi ý sách hay
                        </button>
                        <button class="suggestion-btn" onclick="sendQuickMessage('Cách đặt hàng')">
                            🛒 Cách đặt hàng
                        </button>
                        <button class="suggestion-btn" onclick="sendQuickMessage('Chính sách đổi trả')">
                            🔄 Chính sách đổi trả
                        </button>
                    </div>
                </div>

                <div class="chatbox-input-area">
                    <input type="text"
                           id="chatboxInput"
                           class="chatbox-input"
                           placeholder="Nhập câu hỏi của bạn..."
                           onkeypress="handleChatboxKeyPress(event)">
                    <button onclick="sendChatMessage()" class="chatbox-send-btn">
                        <i class="fas fa-paper-plane"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script>

        const GEMINI_API_KEY = 'AIzaSyBjWNpWYre0Yd8xn4rcmmMq3pW8_mmxjgM';
        const GEMINI_API_URL = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${GEMINI_API_KEY}`;

        function toggleChatbox() {
            const popup = document.getElementById('chatboxPopup');
            if (popup.style.display === 'none' || popup.style.display === '') {
                popup.style.display = 'flex';
                document.getElementById('chatboxInput').focus();
            } else {
                popup.style.display = 'none';
            }
        }

        function addChatMessage(content, isUser) {
            const messagesContainer = document.getElementById('chatboxMessages');

            if (isUser) {
                const welcome = messagesContainer.querySelector('.chatbox-welcome');
                const suggestions = messagesContainer.querySelector('.chatbox-suggestions');
                if (welcome) welcome.remove();
                if (suggestions) suggestions.remove();
            }

            const messageDiv = document.createElement('div');
            messageDiv.className = `chatbox-message ${isUser ? 'user' : 'bot'}`;
            const contentDiv = document.createElement('div');
            contentDiv.className = 'chatbox-message-content';

            contentDiv.innerHTML = isUser ? content : convertMarkdownToHtml(content);

            messageDiv.appendChild(contentDiv);
            messagesContainer.appendChild(messageDiv);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }

        function convertMarkdownToHtml(markdown) {
            let html = markdown.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
            html = html.replace(/\*(.*?)\*/g, '<em>$1</em>');
            html = html.replace(/\n/g, '<br>');
            return html;
        }

        function showTyping() {
            const messagesContainer = document.getElementById('chatboxMessages');
            const typingDiv = document.createElement('div');
            typingDiv.className = 'chatbox-message bot';
            typingDiv.id = 'typingIndicator';
            typingDiv.innerHTML = '<div class="chatbox-typing"><span></span><span></span><span></span></div>';
            messagesContainer.appendChild(typingDiv);
            messagesContainer.scrollTop = messagesContainer.scrollHeight;
        }

        function removeTyping() {
            const typing = document.getElementById('typingIndicator');
            if (typing) typing.remove();
        }

        async function sendChatMessage() {
            const input = document.getElementById('chatboxInput');
            const message = input.value.trim();
            if (!message) return;

            input.value = '';
            input.disabled = true;

            addChatMessage(message, true);
            showTyping();

            // System prompt đã được tối ưu hóa
            const systemPrompt = `Bạn là trợ lý AI thân thiện của ALPHA BOOK - cửa hàng sách trực tuyến hàng đầu Việt Nam.
Nhiệm vụ: Tư vấn, giới thiệu sách, và trả lời câu hỏi về dịch vụ (đặt hàng, giao hàng, thanh toán, đổi trả).
Quy tắc: Luôn trả lời bằng tiếng Việt. Ngắn gọn (2-4 câu), súc tích. Nếu không biết, gợi ý liên hệ hotline: (028) 123 4567.`;

            const fullPrompt = `${systemPrompt}\n\nCâu hỏi của khách hàng: ${message}`;

            try {
                const response = await fetch(GEMINI_API_URL, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        contents: [{
                            parts: [{
                                text: fullPrompt
                            }]
                        }],
                        generationConfig: {
                            temperature: 0.7,
                            topK: 40,
                            topP: 0.95,
                            maxOutputTokens: 1024
                        }
                    })
                });

                removeTyping();

                if (!response.ok) {
                    // Xử lý lỗi HTTP (400, 403, 429, 500...)
                    const errorText = await response.text();
                    console.error(`HTTP error! status: ${response.status}`, errorText);
                    addChatMessage(`Lỗi API: ${response.status}. Vui lòng kiểm tra lại API Key hoặc Quota sử dụng!`, false);
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const data = await response.json();

                if (data.candidates && data.candidates[0] && data.candidates[0].content && data.candidates[0].content.parts) {
                    const reply = data.candidates[0].content.parts[0].text;
                    addChatMessage(reply, false);
                } else if (data.error) {
                    console.error('API Error Response:', data.error);
                    addChatMessage('Xin lỗi, đã có lỗi từ phía máy chủ API. Vui lòng kiểm tra Console để biết chi tiết.', false);
                } else {
                    console.error('Unexpected response structure:', data);
                    addChatMessage('Xin lỗi, tôi không nhận được phản hồi. Vui lòng thử lại!', false);
                }
            } catch (error) {
                removeTyping();
                console.error('Chat error:', error);

                // Cung cấp thông báo lỗi chi tiết hơn
                if (error.message.includes('Failed to fetch')) {
                    addChatMessage('Đã có lỗi kết nối. Vui lòng kiểm tra đường truyền Internet của bạn và thử lại!', false);
                } else if (!error.message.includes('HTTP error!')) {
                    // Lỗi fetch không liên quan đến HTTP status code (ví dụ: CORS, network down)
                    addChatMessage('Đã có lỗi mạng. Vui lòng kiểm tra kết nối internet và tải lại trang!', false);
                }
                // Nếu là lỗi HTTP, thông báo đã được đưa ra ở trên.
            }

            input.disabled = false;
            input.focus();
        }

        function sendQuickMessage(text) {
            document.getElementById('chatboxInput').value = text;
            sendChatMessage();
        }

        function handleChatboxKeyPress(event) {
            if (event.key === 'Enter') {
                event.preventDefault();
                sendChatMessage();
            }
        }
    </script>
