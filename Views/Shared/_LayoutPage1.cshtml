<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trang Chủ - ALPHA BOOK</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" xintegrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" xintegrity="sha512-SnH5WK+bZxgPHs44uWIX+LLMDJzL31r+2K6wY3s+61A3z4uYpL6R6J9l+z6I1A5g==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        /* Thiết lập font và màu nền */
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f0f2f5; /* Nền xám nhạt */
            color: #1a202c;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            width: 1500px
        }
        /* Custom styles cho thanh tìm kiếm */
        .search-container input {
            padding-right: 2.5rem;
            border-radius: 0.5rem;
            border: 2px solid #ced4da;
        }

            .search-container input:focus {
                border-color: #0d6efd; /* Blue focus */
                box-shadow: none;
            }

        .product-card {
            border-radius: 1rem; /* Rounded corners */
            transition: transform 0.3s, box-shadow 0.3s;
        }

            .product-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
            }
        /* Sticky Header */
        header {
            top: 0;
            z-index: 1030;
            position: sticky;
        }

        /* Styles cho Chatbot */
        .chat-widget-button {
            position: fixed;
            bottom: 20px;
            right: 20px;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            color: white;
            border: none;
            font-size: 28px;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(13, 110, 253, 0.4);
            z-index: 9999;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .chat-widget-button:hover {
                transform: scale(1.1);
                box-shadow: 0 6px 30px rgba(13, 110, 253, 0.6);
            }

        .chat-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: #dc3545;
            color: white;
            font-size: 10px;
            font-weight: bold;
            padding: 2px 6px;
            border-radius: 10px;
            border: 2px solid white;
        }

        .chatbox-popup {
            position: fixed;
            bottom: 90px;
            right: 20px;
            width: 380px;
            height: 550px;
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.2);
            z-index: 9998;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .chatbox-header {
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            color: white;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .chatbox-header-content {
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .chatbox-header-content i {
                font-size: 24px;
            }

            .chatbox-header-content h4 {
                margin: 0;
                font-size: 16px;
                font-weight: 600;
            }

            .chatbox-header-content p {
                margin: 0;
                font-size: 12px;
                opacity: 0.9;
            }

        .chatbox-close-btn {
            background: rgba(255,255,255,0.2);
            border: none;
            color: white;
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 16px;
        }

        .chatbox-body {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: #f8f9fa;
        }

        .chatbox-messages {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
        }

        .chatbox-welcome {
            text-align: center;
            padding: 20px;
            background: white;
            border-radius: 15px;
            margin-bottom: 15px;
        }

            .chatbox-welcome i {
                font-size: 40px;
                color: #0d6efd;
                margin-bottom: 10px;
            }

            .chatbox-welcome h5 {
                margin: 10px 0 5px 0;
                color: #333;
                font-size: 18px;
            }

            .chatbox-welcome p {
                margin: 0;
                color: #6c757d;
                font-size: 14px;
            }

        .chatbox-suggestions {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .suggestion-btn {
            background: white;
            border: 2px solid #e9ecef;
            padding: 12px 15px;
            border-radius: 12px;
            cursor: pointer;
            font-size: 14px;
            text-align: left;
            transition: all 0.2s;
            color: #333;
        }

            .suggestion-btn:hover {
                background: #0d6efd;
                color: white;
                border-color: #0d6efd;
                transform: translateX(5px);
            }

        .chatbox-message {
            display: flex;
            margin-bottom: 15px;
        }

            .chatbox-message.user {
                justify-content: flex-end;
            }

        .chatbox-message-content {
            max-width: 75%;
            padding: 12px 15px;
            border-radius: 15px;
            font-size: 14px;
            line-height: 1.5;
        }

        .chatbox-message.bot .chatbox-message-content {
            background: white;
            color: #333;
            border-bottom-left-radius: 5px;
        }

        .chatbox-message.user .chatbox-message-content {
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            color: white;
            border-bottom-right-radius: 5px;
        }

        .chatbox-typing {
            display: flex;
            gap: 4px;
            padding: 12px 15px;
            background: white;
            border-radius: 15px;
            width: fit-content;
        }

            .chatbox-typing span {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: #0d6efd;
                animation: typing 1.4s infinite;
            }

                .chatbox-typing span:nth-child(2) {
                    animation-delay: 0.2s;
                }

                .chatbox-typing span:nth-child(3) {
                    animation-delay: 0.4s;
                }

        @@keyframes typing {
            0%, 60%, 100% {
                transform: translateY(0);
                opacity: 0.7;
            }

            30% {
                transform: translateY(-8px);
                opacity: 1;
            }
        }

        .chatbox-input-area {
            padding: 15px;
            background: white;
            border-top: 1px solid #e9ecef;
            display: flex;
            gap: 10px;
        }

        .chatbox-input {
            flex: 1;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 25px;
            font-size: 14px;
            outline: none;
        }

            .chatbox-input:focus {
                border-color: #0d6efd;
            }

        .chatbox-send-btn {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            color: white;
            border: none;
            cursor: pointer;
            font-size: 16px;
        }

            .chatbox-send-btn:hover {
                transform: scale(1.1);
            }
    </style>
</head>
<body>

