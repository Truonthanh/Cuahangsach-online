
@{
    ViewBag.Title = "TinTuc";
    Layout = "~/Views/Shared/_LayoutPage1.cshtml";
}

<style>

    .article-card {
        border: none;
        border-radius: 1rem;
        transition: box-shadow 0.3s;
    }

        .article-card:hover {
            box-shadow: 0 8px 15px rgba(0, 0, 0, 0.1);
        }

    .article-image {
        height: 220px;
        object-fit: cover;
        border-top-left-radius: 1rem;
        border-top-right-radius: 1rem;
    }

    .featured-article-image {
        height: 350px;
        object-fit: cover;
        border-radius: 1rem;
    }

    .sidebar-item:hover h6 {
        color: #0d6efd !important;
    }
</style>

<main class="container my-5 flex-grow-1">
    <div class="row">
        <!-- Cột phải: NỘI DUNG CHÍNH (Banner, Sản phẩm nổi bật) -->
        <section class="col-lg-8">
            <h1 class="display-5 fw-bold text-primary mb-4 border-bottom pb-2">Tin Tức & Bài Viết Mới</h1>
            <!-- Bài viết Nổi bật (Featured Article) -->
            <a href="#" class="text-decoration-none text-body mb-5 d-block bg-white p-3 rounded-3 shadow-lg article-card">
                <div class="row g-4">
                    <div class="col-md-5 mt-5">
                        <img src="https://placehold.co/800x600/28a745/ffffff?text=Bài+Nổi+Bật" alt="Ảnh minh họa" class="featured-article-image w-100">
                    </div>
                    <div class="col-md-7 d-flex flex-column justify-content-center">
                        <span class="badge bg-danger mb-2 fw-bold">Nổi Bật</span>
                        <h2 class="h3 fw-bold text-primary">
                            Top 10 Cuốn Sách Phát Triển Bản Thân Thay Đổi Cuộc Đời Bạn Năm 2025
                        </h2>
                        <p class="text-muted small mb-3">
                            <i class="fas fa-calendar-alt me-1"></i> 01/08/2025 |
                            <i class="fas fa-user me-1"></i> Tác giả: Alpha Review
                        </p>
                        <p class="mt-0">
                            Một danh sách tổng hợp những cuốn sách có sức ảnh hưởng mạnh mẽ nhất, giúp bạn định hình lại tư duy, cải thiện kỹ năng và đạt được mục tiêu cá nhân...
                        </p>
                        <small class="text-primary fw-bold">Đọc tiếp <i class="fas fa-arrow-right ms-1"></i></small>
                    </div>
                   
                </div>
            </a>

            <!-- Danh sách Bài viết Mới -->
            <h3 class="fs-4 fw-bold mt-4 mb-4 text-secondary border-bottom pb-2">
                Tất Cả Bài Viết
            </h3>

            <div class="row row-cols-1 g-4">

                <!-- Bài viết 1 -->
                <div class="col">
                    <div class="card article-card shadow-sm h-100">
                        <a href="#" class="row g-0 text-decoration-none text-body">
                            <div class="col-md-4">
                                <img src="https://placehold.co/600x400/0d6efd/ffffff?text=Văn+học" alt="Ảnh minh họa" class="img-fluid article-image w-100" style="height: 100%; border-top-right-radius: 0; border-bottom-left-radius: 1rem;">
                            </div>
                            <div class="col-md-8">
                                <div class="card-body">
                                    <span class="badge bg-primary-subtle text-primary mb-2">Văn Học</span>
                                    <h5 class="card-title fw-bold">Phân Tích Sâu Sắc Tác Phẩm 'Chiếc Thuyền Ngoài Xa' của Nguyễn Minh Châu</h5>
                                    <p class="card-text small text-muted mb-2">
                                        <i class="fas fa-calendar-alt me-1"></i> 28/07/2025 |
                                        <i class="fas fa-comment me-1"></i> 15 bình luận
                                    </p>
                                    <p class="card-text d-none d-sm-block">
                                        Khám phá những lớp ý nghĩa ẩn giấu và giá trị nhân đạo sâu sắc trong truyện ngắn nổi tiếng này...
                                    </p>
                                    <small class="text-primary fw-bold">Đọc tiếp <i class="fas fa-arrow-right ms-1"></i></small>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>

                <!-- Bài viết 2 -->
                <div class="col">
                    <div class="card article-card shadow-sm h-100">
                        <a href="#" class="row g-0 text-decoration-none text-body">
                            <div class="col-md-4">
                                <img src="https://placehold.co/600x400/ffc107/212529?text=Kinh+tế" alt="Ảnh minh họa" class="img-fluid article-image w-100" style="height: 100%; border-top-right-radius: 0; border-bottom-left-radius: 1rem;">
                            </div>
                            <div class="col-md-8">
                                <div class="card-body">
                                    <span class="badge bg-warning-subtle text-warning mb-2">Kinh Tế</span>
                                    <h5 class="card-title fw-bold">Bí quyết "Đầu Tư Theo Warren Buffett": Áp dụng cho người trẻ Việt</h5>
                                    <p class="card-text small text-muted mb-2">
                                        <i class="fas fa-calendar-alt me-1"></i> 25/07/2025 |
                                        <i class="fas fa-comment me-1"></i> 22 bình luận
                                    </p>
                                    <p class="card-text d-none d-sm-block">
                                        Phân tích các nguyên tắc đầu tư giá trị và cách thức áp dụng chúng trong thị trường tài chính Việt Nam...
                                    </p>
                                    <small class="text-primary fw-bold">Đọc tiếp <i class="fas fa-arrow-right ms-1"></i></small>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>

                <!-- Bài viết 3 -->
                <div class="col">
                    <div class="card article-card shadow-sm h-100">
                        <a href="#" class="row g-0 text-decoration-none text-body">
                            <div class="col-md-4">
                                <img src="https://placehold.co/600x400/dc3545/ffffff?text=Tâm+lý" alt="Ảnh minh họa" class="img-fluid article-image w-100" style="height: 100%; border-top-right-radius: 0; border-bottom-left-radius: 1rem;">
                            </div>
                            <div class="col-md-8">
                                <div class="card-body">
                                    <span class="badge bg-danger-subtle text-danger mb-2">Tâm Lý Học</span>
                                    <h5 class="card-title fw-bold">Làm chủ Cảm Xúc: Phương pháp từ 'Duy Lý Cảm Xúc' (Emotional Intelligence)</h5>
                                    <p class="card-text small text-muted mb-2">
                                        <i class="fas fa-calendar-alt me-1"></i> 20/07/2025 |
                                        <i class="fas fa-comment me-1"></i> 18 bình luận
                                    </p>
                                    <p class="card-text d-none d-sm-block">
                                        Tìm hiểu về trí tuệ cảm xúc và các bước thực hành để nâng cao khả năng tự kiểm soát và tương tác xã hội...
                                    </p>
                                    <small class="text-primary fw-bold">Đọc tiếp <i class="fas fa-arrow-right ms-1"></i></small>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

            

        </section>
        <!-- Cột phải: SIDEBAR (Danh mục & Phổ biến) -->
        <aside class="col-lg-4">
            <div class="bg-white p-4 rounded-3 shadow-lg mb-5">
                <h4 class="fs-5 fw-bold mb-4 text-primary border-bottom pb-2 d-flex align-items-center">
                    <i class="fas fa-folder-open me-2"></i>
                    Danh Mục
                </h4>
                <div class="list-group list-group-flush">
                    <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 fw-medium">
                        <span class="text-muted">Review Sách (5)</span>
                        <i class="fas fa-chevron-right small text-primary"></i>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 fw-medium">
                        <span class="text-muted">Tin Khuyến Mãi (3)</span>
                        <i class="fas fa-chevron-right small text-primary"></i>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 fw-medium">
                        <span class="text-muted">Văn Hóa Đọc (7)</span>
                        <i class="fas fa-chevron-right small text-primary"></i>
                    </a>
                    <a href="#" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center border-0 fw-medium">
                        <span class="text-muted">Kỹ Năng & Phát Triển (10)</span>
                        <i class="fas fa-chevron-right small text-primary"></i>
                    </a>
                </div>
            </div>

            <div class="bg-white p-4 rounded-3 shadow-lg">
                <h4 class="fs-5 fw-bold mb-4 text-primary border-bottom pb-2 d-flex align-items-center">
                    <i class="fas fa-star me-2"></i>
                    Bài Viết Phổ Biến
                </h4>

                <!-- Bài viết phổ biến 1 -->
                <div class="d-flex mb-3 pb-3 border-bottom sidebar-item">
                    <img src="https://placehold.co/100x70/007bff/ffffff?text=Pop+1" alt="Bài phổ biến" class="rounded me-3" style="width: 100px; height: 70px; object-fit: cover;">
                    <div>
                        <span class="badge bg-info-subtle text-info mb-1 small">Văn Hóa</span>
                        <a href="#" class="text-decoration-none text-body">
                            <h6 class="fw-semibold mb-1 text-truncate" style="max-width: 200px;">
                                Tầm quan trọng của việc đọc sách giấy trong kỷ nguyên số
                            </h6>
                        </a>
                        <p class="small text-muted mb-0">2 ngày trước</p>
                    </div>
                </div>

                <!-- Bài viết phổ biến 2 -->
                <div class="d-flex mb-3 pb-3 border-bottom sidebar-item">
                    <img src="https://placehold.co/100x70/6c757d/ffffff?text=Pop+2" alt="Bài phổ biến" class="rounded me-3" style="width: 100px; height: 70px; object-fit: cover;">
                    <div>
                        <span class="badge bg-secondary-subtle text-secondary mb-1 small">Kỹ Năng</span>
                        <a href="#" class="text-decoration-none text-body">
                            <h6 class="fw-semibold mb-1 text-truncate" style="max-width: 200px;">
                                Bí quyết đọc nhanh và hiệu quả hơn
                            </h6>
                        </a>
                        <p class="small text-muted mb-0">1 tuần trước</p>
                    </div>
                </div>

                <!-- Bài viết phổ biến 3 -->
                <div class="d-flex sidebar-item">
                    <img src="https://placehold.co/100x70/20c997/ffffff?text=Pop+3" alt="Bài phổ biến" class="rounded me-3" style="width: 100px; height: 70px; object-fit: cover;">
                    <div>
                        <span class="badge bg-success-subtle text-success mb-1 small">Review</span>
                        <a href="#" class="text-decoration-none text-body">
                            <h6 class="fw-semibold mb-1 text-truncate" style="max-width: 200px;">
                                Review sách 'Nhà Giả Kim'
                            </h6>
                        </a>
                        <p class="small text-muted mb-0">2 tuần trước</p>
                    </div>
                </div>
            </div>
        </aside>
    </div>
   
</main>




