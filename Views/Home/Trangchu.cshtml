@using Nhom06_QuanLyBanSah.Models
@model List<SACH>

@{
    ViewBag.Title = "Trang chủ";
    Layout = "~/Views/Shared/_LayoutPage1.cshtml";
}

<main class="container my-5 flex-grow-1">
    <div class="row">

        
       

        <!-- Cột phải: NỘI DUNG CHÍNH -->
        <section class="col-lg-12">

            <!-- Banner Quảng cáo -->
            <div class="row">
                <div class="col">

                    <div id="carouselExampleControls" class="carousel slide w-100 mx-auto mt-3" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                                <img src="/Images/Anh1.png" class="d-block w-100" alt="Ảnh 1" />
                            </div>
                            <div class="carousel-item">
                                <img src="/Images/Anh2.png" class="d-block w-100" alt="Ảnh 2" />
                            </div>
                            <div class="carousel-item">
                                <img src="/Images/Anh3.png" class="d-block w-100" alt="Ảnh 3" />
                            </div>
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleControls" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleControls" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>

                </div>
            </div>

            <!-- Sản phẩm Nổi bật -->
            <h2 class="fs-3 fw-bold mb-4 text-primary border-bottom pb-2 mt-5">Sách Bán Chạy Nhất</h2>
            <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-4">
                @foreach (var item in Model.Take(4)) // Hiển thị 4 sản phẩm nổi bật
                {
                    <div class="col">
                        <div class="card product-card h-100 shadow-sm" style="padding-top:20px">
                            <img src="~/HinhSP/@item.AnhBia" alt="@item.AnhBia" class="w-32 h-48 object-cover rounded-md shadow-md mb-3" />

                            <div class="card-body text-center">
                                <p class="card-text text-muted small mb-1">@item.THELOAI.TenTheLoai</p>
                                <h5 class="card-title fw-bold mb-2 text-truncate" >
                                    <a href="@Url.Action("ChiTietSanPham", "Home", new { @ms = item.MaSach })"style="text-decoration:none">
                                        @item.TenSach
                                    </a>
                                </h5>
                                <p class="fs-4 fw-bolder text-danger">@String.Format("{0:N0} VNĐ", item.GiaBan)</p>
                                <a href="@Url.Action("ChiTietSanPham", "Home", new { @ms = item.MaSach })"
                                   class="btn btn-primary w-100 small fw-semibold">
                                    Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Sách Mới Phát Hành -->
            <h2 class="fs-3 fw-bold mt-5 mb-4 text-primary border-bottom pb-2">Sách Mới Phát Hành</h2>
            <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-4">
                @foreach (var item in Model.Skip(4).Take(4)) // Hiển thị 4 sản phẩm mới
                {
                    <div class="col">
                        <div class="card product-card h-100 shadow-sm"style="padding-top:20px">
                            <img src="~/HinhSP/@item.AnhBia" alt="@item.AnhBia" class="w-32 h-48 object-cover rounded-md shadow-md mb-3" />

                            <div class="card-body text-center">
                                <p class="card-text text-muted small mb-1">@item.THELOAI.TenTheLoai</p>
                                <h5 class="card-title fw-bold mb-2 text-truncate" >
                                    <a href="@Url.Action("ChiTietSanPham", "Home", new { @ms = item.MaSach })"style="text-decoration:none">
                                        @item.TenSach
                                    </a>
                                </h5>
                                <p class="fs-4 fw-bolder text-danger">@String.Format("{0:N0} VNĐ", item.GiaBan)</p>
                                <a href="@Url.Action("ChiTietSanPham", "Home", new { @ms = item.MaSach })"
                                   class="btn btn-primary w-100 small fw-semibold">
                                    Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

        </section>
    </div>
</main>


