@{
    ViewBag.Title = "Thanh toán thành công";
    Layout = "~/Views/Shared/_LayoutPage1.cshtml";
}

<style>
    .success-container {
        max-width: 900px;
        margin: 50px auto;
        padding: 20px;
        animation: fadeIn 0.5s ease-in;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .success-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .success-header {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
        padding: 50px 20px;
        text-align: center;
        position: relative;
    }

    .success-icon {
        font-size: 100px;
        animation: successPulse 1s ease-in-out;
        filter: drop-shadow(0 5px 15px rgba(0,0,0,0.2));
    }

    @@keyframes successPulse {
        0% {
            transform: scale(0);
            opacity: 0;
        }

        50% {
            transform: scale(1.2);
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    .success-checkmark {
        width: 100px;
        height: 100px;
        margin: 0 auto 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(10px);
    }

    .success-body {
        padding: 50px 40px;
    }

    .order-info-card {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        border-radius: 15px;
        padding: 30px;
        margin: 30px 0;
        box-shadow: 0 5px 20px rgba(0,0,0,0.08);
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px 0;
        border-bottom: 1px solid rgba(255,255,255,0.5);
    }

        .info-row:last-child {
            border-bottom: none;
        }

    .info-label {
        font-weight: 600;
        color: #555;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .info-value {
        font-size: 18px;
        font-weight: 700;
        color: #2c3e50;
    }

    .order-id {
        color: #11998e;
        font-size: 24px;
    }

    .transaction-id {
        color: #38ef7d;
        font-size: 20px;
    }

    .amount-display {
        color: #e74c3c;
        font-size: 28px;
    }

    .success-message-box {
        background: #d4edda;
        border-left: 5px solid #28a745;
        padding: 20px;
        border-radius: 10px;
        margin: 30px 0;
    }

        .success-message-box i {
            font-size: 24px;
            color: #28a745;
            margin-right: 10px;
        }

    .timeline {
        margin: 40px 0;
        padding: 20px;
        background: #f8f9fa;
        border-radius: 15px;
    }

    .timeline-item {
        display: flex;
        align-items: flex-start;
        margin: 20px 0;
        position: relative;
    }

    .timeline-icon {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-right: 20px;
        font-size: 18px;
        flex-shrink: 0;
    }

    .timeline-content h6 {
        margin: 0 0 5px 0;
        color: #2c3e50;
        font-weight: 600;
    }

    .timeline-content p {
        margin: 0;
        color: #7f8c8d;
        font-size: 14px;
    }

    .btn-action {
        padding: 15px 35px;
        font-size: 16px;
        font-weight: 600;
        border-radius: 10px;
        margin: 10px;
        transition: all 0.3s ease;
        border: none;
    }

    .btn-primary-custom {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

        .btn-primary-custom:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.4);
        }

    .btn-outline-custom {
        background: white;
        color: #667eea;
        border: 2px solid #667eea;
    }

        .btn-outline-custom:hover {
            background: #667eea;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(102, 126, 234, 0.3);
        }

    .contact-box {
        background: #fff3cd;
        border-radius: 10px;
        padding: 20px;
        margin-top: 30px;
    }

        .contact-box h6 {
            color: #856404;
            font-weight: 600;
        }

    .confetti {
        position: absolute;
        width: 10px;
        height: 10px;
        background: #f0f;
        animation: confetti-fall 3s ease-in-out infinite;
    }

    @@keyframes confetti-fall {
        to {
            transform: translateY(100vh) rotate(360deg);
            opacity: 0;
        }
    }
</style>

<div class="success-container">
    <div class="success-card">
        <div class="success-header">
            <div class="success-checkmark">
                <div class="success-icon">
                    <i class="fas fa-check-circle"></i>
                </div>
            </div>
            <h1 class="display-4 mb-2">Thanh Toán Thành Công!</h1>
            <p class="lead mb-0">Cảm ơn bạn đã tin tưởng và mua hàng</p>
        </div>

        <div class="success-body">
            <div class="success-message-box">
                <div class="d-flex align-items-center">
                    <i class="fas fa-check-circle"></i>
                    <div>
                        <strong>@ViewBag.Message</strong>
                        <p class="mb-0 mt-2">
                            Đơn hàng của bạn đã được xác nhận và đang được xử lý.
                            Chúng tôi sẽ giao hàng đến bạn trong thời gian sớm nhất.
                        </p>
                    </div>
                </div>
            </div>

            <div class="order-info-card">
                <h4 class="text-center mb-4">
                    <i class="fas fa-file-invoice"></i> Thông Tin Giao Dịch
                </h4>

                <div class="info-row">
                    <span class="info-label">
                        <i class="fas fa-receipt text-primary"></i>
                        Mã đơn hàng
                    </span>
                    <span class="info-value order-id">#@ViewBag.OrderId</span>
                </div>

                @if (ViewBag.TransactionId != null)
                {
                    <div class="info-row">
                        <span class="info-label">
                            <i class="fas fa-credit-card text-success"></i>
                            Mã giao dịch VNPay
                        </span>
                        <span class="info-value transaction-id">@ViewBag.TransactionId</span>
                    </div>
                }

                @if (ViewBag.Amount != null)
                {
                    <div class="info-row">
                        <span class="info-label">
                            <i class="fas fa-money-bill-wave text-danger"></i>
                            Số tiền thanh toán
                        </span>
                        <span class="info-value amount-display">@String.Format("{0:N0}", ViewBag.Amount) ₫</span>
                    </div>
                }

                <div class="info-row">
                    <span class="info-label">
                        <i class="fas fa-clock text-warning"></i>
                        Thời gian
                    </span>
                    <span class="info-value">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
                </div>
            </div>

            <div class="timeline">
                <h5 class="text-center mb-4">
                    <i class="fas fa-truck"></i> Tiến Trình Đơn Hàng
                </h5>

                <div class="timeline-item">
                    <div class="timeline-icon">
                        <i class="fas fa-check"></i>
                    </div>
                    <div class="timeline-content">
                        <h6>Đơn hàng đã được đặt</h6>
                        <p>Chúng tôi đã nhận được đơn hàng của bạn</p>
                    </div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-icon">
                        <i class="fas fa-box"></i>
                    </div>
                    <div class="timeline-content">
                        <h6>Đang chuẩn bị hàng</h6>
                        <p>Đơn hàng đang được đóng gói (1-2 ngày)</p>
                    </div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-icon">
                        <i class="fas fa-shipping-fast"></i>
                    </div>
                    <div class="timeline-content">
                        <h6>Đang giao hàng</h6>
                        <p>Đơn hàng sẽ được giao đến bạn (2-3 ngày)</p>
                    </div>
                </div>

                <div class="timeline-item">
                    <div class="timeline-icon">
                        <i class="fas fa-home"></i>
                    </div>
                    <div class="timeline-content">
                        <h6>Giao hàng thành công</h6>
                        <p>Bạn nhận được hàng và hoàn tất đơn hàng</p>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5">
                <a href="@Url.Action("ChiTietDonHang", "Home", new { ma = ViewBag.OrderId })"
                   class="btn btn-primary-custom btn-action">
                    <i class="fas fa-eye"></i> Xem Chi Tiết Đơn Hàng
                </a>
                <a href="@Url.Action("LichSuDonHang", "Home")"
                   class="btn btn-outline-custom btn-action">
                    <i class="fas fa-history"></i> Lịch Sử Đơn Hàng
                </a>
                <a href="@Url.Action("SanPham", "Home")"
                   class="btn btn-outline-custom btn-action">
                    <i class="fas fa-shopping-bag"></i> Tiếp Tục Mua Sắm
                </a>
            </div>

            <div class="contact-box">
                <h6><i class="fas fa-info-circle"></i> Lưu ý quan trọng</h6>
                <ul class="mb-0">
                    <li>Email xác nhận đã được gửi đến địa chỉ email của bạn</li>
                    <li>Vui lòng kiểm tra email để biết thông tin chi tiết về đơn hàng</li>
                    <li>Nếu có bất kỳ thắc mắc nào, vui lòng liên hệ hotline: <strong>1900 xxxx</strong></li>
                    <li>Hoặc email: <strong>support@bookstore.com</strong></li>
                </ul>
            </div>
        </div>
    </div>
</div>

<script>
    // Tạo hiệu ứng confetti
    function createConfetti() {
        const colors = ['#11998e', '#38ef7d', '#667eea', '#764ba2', '#f093fb', '#f5576c'];
        for (let i = 0; i < 50; i++) {
            setTimeout(() => {
                const confetti = document.createElement('div');
                confetti.className = 'confetti';
                confetti.style.left = Math.random() * 100 + '%';
                confetti.style.background = colors[Math.floor(Math.random() * colors.length)];
                confetti.style.animationDelay = Math.random() * 3 + 's';
                confetti.style.animationDuration = (Math.random() * 3 + 2) + 's';
                document.querySelector('.success-header').appendChild(confetti);

                setTimeout(() => confetti.remove(), 5000);
            }, i * 50);
        }
    }

    // Chạy confetti khi trang load
    window.addEventListener('load', createConfetti);
</script>