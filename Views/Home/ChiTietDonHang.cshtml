@{
    ViewBag.Title = "ChiTietDonHang";
    Layout = "~/Views/Shared/_LayoutPage1.cshtml";
    var don = ViewBag.Don as Nhom06_QuanLyBanSah.Models.DONHANG;
    var yeuCauHuy = ViewBag.YeuCauHuy as Nhom06_QuanLyBanSah.Models.HOANTRA;
}
@model List<Nhom06_QuanLyBanSah.Models.CHITIETDONHANG>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-5 fw-bold text-primary">Chi tiết đơn hàng #@don.MaDonHang</h1>
        <a href="@Url.Action("LichSuDonHang", "Home")" class="btn btn-outline-primary">
            <i class="fas fa-arrow-left me-2"></i>Quay Lại
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row">
        <!-- Cột trái: Thông tin đơn hàng -->
        <div class="col-lg-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle me-2"></i>Thông Tin Đơn Hàng</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <p><strong>Người nhận:</strong> @don.TAIKHOAN.HoTen</p>
                            <p><strong>Ngày đặt:</strong> @don.NgayDatHang</p>
                            <p><strong>Địa chỉ giao hàng:</strong> @don.DiaChiGiaoHang</p>
                        </div>
                        <div class="col-md-6 mb-3">
                            <p><strong>Phương thức thanh toán:</strong> <span class="badge bg-info">@don.PhuongThucThanhToan</span></p>
                            <p>
                                <strong>Trạng thái:</strong>
                                @switch (don.TinhTrangGiaoHang)
                                {
                                    case "Chờ xử lý":
                                        <span class="badge bg-secondary">Chờ xử lý</span>
                                        break;
                                    case "Yêu cầu hủy":
                                        <span class="badge bg-warning">Yêu cầu hủy</span>
                                        break;
                                    case "Đã xác nhận":
                                        <span class="badge bg-info">Đã xác nhận</span>
                                        break;
                                    case "Đang vận chuyển":
                                        <span class="badge bg-primary">Đang vận chuyển</span>
                                        break;
                                    case "Đã giao hàng thành công":
                                        <span class="badge bg-success">Đã giao</span>
                                        break;
                                    case "Đã hủy":
                                        <span class="badge bg-danger">Đã hủy</span>
                                        break;
                                    default:
                                        <span class="badge bg-secondary">@don.TinhTrangGiaoHang</span>
                                        break;
                                }
                            </p>
                            <p><strong>Tổng tiền:</strong> <span class="text-danger fw-bold">@String.Format("{0:N0} VNĐ", don.TongTien)</span></p>
                        </div>
                    </div>

                    @* Hiển thị thông tin yêu cầu hủy nếu có *@
                    @if (yeuCauHuy != null)
                    {
                        <div class="alert alert-warning mt-3">
                            <h6 class="alert-heading"><i class="fas fa-exclamation-triangle me-2"></i>Yêu Cầu Hủy Đơn Hàng</h6>
                            <p class="mb-1"><strong>Lý do:</strong> @yeuCauHuy.LyDo</p>
                            <p class="mb-1"><strong>Ngày yêu cầu:</strong> @yeuCauHuy.NgayYeuCau.Value.ToString("dd/MM/yyyy HH:mm")</p>
                            <p class="mb-0">
                                <strong>Trạng thái xử lý:</strong>
                                @if (yeuCauHuy.TrangThai == "Chờ xử lý")
                                {
                                    <span class="badge bg-warning">Đang chờ admin xử lý</span>
                                }
                                else if (yeuCauHuy.TrangThai == "Đã xử lý")
                                {
                                    <span class="badge bg-success">Đã xử lý</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@yeuCauHuy.TrangThai</span>
                                }
                            </p>

                            @* Nút hủy yêu cầu hủy (nếu đổi ý) *@
                            @if (yeuCauHuy.TrangThai == "Chờ xử lý")
                            {
                                <button type="button" class="btn btn-sm btn-outline-danger mt-2" onclick="huyYeuCauHuy()">
                                    <i class="fas fa-times me-1"></i>Hủy Yêu Cầu Này
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Chi tiết sản phẩm -->
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-box me-2"></i>Chi Tiết Sản Phẩm</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-bordered table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>Sách</th>
                                    <th class="text-end">Giá</th>
                                    <th class="text-center">Số lượng</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ct in Model)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="~/HinhSP/@ct.SACH.AnhBia" alt="@ct.SACH.TenSach"
                                                     class="img-thumbnail me-3" style="width: 60px; height: 80px; object-fit: cover;">
                                                <div>
                                                    <strong>@ct.SACH.TenSach</strong>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-end">@String.Format("{0:N0} VNĐ", ct.GiaBanTaiThoiDiem)</td>
                                        <td class="text-center"><span class="badge bg-primary">@ct.SoLuong</span></td>
                                        <td class="text-end fw-bold text-danger">@String.Format("{0:N0} VNĐ", ct.GiaBanTaiThoiDiem * ct.SoLuong)</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-light">
                                <tr>
                                    <td colspan="3" class="text-end fw-bold">Tổng Cộng:</td>
                                    <td class="text-end">
                                        <h5 class="mb-0 text-danger fw-bold">@String.Format("{0:N0} VNĐ", don.TongTien)</h5>
                                    </td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cột phải: Hành động -->
        <div class="col-lg-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-tools me-2"></i>Thao Tác</h5>
                </div>
                <div class="card-body">
                    @if (don.TinhTrangGiaoHang == "Chờ xử lý" && yeuCauHuy == null)
                    {
                        <button type="button" class="btn btn-danger w-100" data-bs-toggle="modal" data-bs-target="#huyDonModal">
                            <i class="fas fa-times-circle me-2"></i>Hủy Đơn Hàng
                        </button>
                        <p class="text-muted small mt-2 mb-0">
                            <i class="fas fa-info-circle me-1"></i>Bạn chỉ có thể hủy đơn hàng khi đơn đang ở trạng thái "Chờ xử lý"
                        </p>
                    }
                    else if (don.TinhTrangGiaoHang == "Yêu cầu hủy")
                    {
                        <div class="alert alert-warning mb-0">
                            <i class="fas fa-clock me-2"></i>Yêu cầu hủy đơn đang được xử lý
                        </div>
                    }
                    else if (don.TinhTrangGiaoHang == "Đã hủy")
                    {
                        <div class="alert alert-danger mb-0">
                            <i class="fas fa-ban me-2"></i>Đơn hàng đã bị hủy
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info mb-0">
                            <i class="fas fa-info-circle me-2"></i>
                            Không thể hủy đơn hàng ở trạng thái hiện tại.
                            Vui lòng liên hệ hotline để được hỗ trợ.
                        </div>
                    }
                </div>
            </div>

            <!-- Hỗ trợ -->
            <div class="card shadow-sm mt-3">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-headset me-2"></i>Hỗ Trợ</h5>
                </div>
                <div class="card-body">
                    <p class="mb-2"><i class="fas fa-phone me-2 text-primary"></i><strong>Hotline:</strong> 1900 1234</p>
                    <p class="mb-2"><i class="fas fa-envelope me-2 text-primary"></i><strong>Email:</strong> support@bookstore.com</p>
                    <p class="mb-0"><i class="fas fa-clock me-2 text-primary"></i><strong>Giờ làm việc:</strong> 8:00 - 22:00</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Hủy Đơn Hàng -->
<div class="modal fade" id="huyDonModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="fas fa-exclamation-triangle me-2"></i>Hủy Đơn Hàng</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-danger fw-bold">Bạn có chắc muốn hủy đơn hàng này không?</p>
                <p class="text-muted small">Vui lòng chọn lý do hủy đơn:</p>

                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="lyDoHuy" id="lydo1" value="Tôi muốn đổi địa chỉ giao hàng" checked>
                    <label class="form-check-label" for="lydo1">
                        Tôi muốn đổi địa chỉ giao hàng
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="lyDoHuy" id="lydo2" value="Tôi muốn thay đổi sản phẩm trong đơn hàng">
                    <label class="form-check-label" for="lydo2">
                        Tôi muốn thay đổi sản phẩm trong đơn hàng
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="lyDoHuy" id="lydo3" value="Thời gian giao hàng quá lâu">
                    <label class="form-check-label" for="lydo3">
                        Thời gian giao hàng quá lâu
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="lyDoHuy" id="lydo4" value="Tìm thấy giá tốt hơn ở nơi khác">
                    <label class="form-check-label" for="lydo4">
                        Tìm thấy giá tốt hơn ở nơi khác
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="lyDoHuy" id="lydo5" value="Đặt nhầm sản phẩm">
                    <label class="form-check-label" for="lydo5">
                        Đặt nhầm sản phẩm
                    </label>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="radio" name="lyDoHuy" id="lydo6" value="Lý do khác">
                    <label class="form-check-label" for="lydo6">
                        Lý do khác
                    </label>
                </div>

                <div id="lyDoKhacContainer" style="display:none;">
                    <textarea id="lyDoKhac" class="form-control" rows="3" placeholder="Vui lòng nhập lý do..."></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="fas fa-times me-2"></i>Đóng
                </button>
                <button type="button" class="btn btn-danger" onclick="xacNhanHuyDon()">
                    <i class="fas fa-check me-2"></i>Xác Nhận Hủy
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    // Hiển thị textarea khi chọn "Lý do khác"
    $('input[name="lyDoHuy"]').change(function() {
        if ($('#lydo6').is(':checked')) {
            $('#lyDoKhacContainer').slideDown();
        } else {
            $('#lyDoKhacContainer').slideUp();
            $('#lyDoKhac').val('');
        }
    });

    function xacNhanHuyDon() {
        var lyDo = $('input[name="lyDoHuy"]:checked').val();

        // Nếu chọn "Lý do khác", lấy nội dung từ textarea
        if ($('#lydo6').is(':checked')) {
            var lyDoKhac = $('#lyDoKhac').val().trim();
            if (lyDoKhac === '') {
                alert('Vui lòng nhập lý do hủy đơn!');
                return;
            }
            lyDo = lyDoKhac;
        }

        $.ajax({
            url: '@Url.Action("YeuCauHuyDonHang", "Home")',
            type: 'POST',
            data: {
                __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val(),
                maDonHang: @don.MaDonHang,
                lyDoHuy: lyDo
            },
            success: function(response) {
                if (response.success) {
                    alert(response.message);
                    $('#huyDonModal').modal('hide');
                    location.reload();
                } else {
                    alert(response.message);
                }
            },
            error: function() {
                alert('Có lỗi xảy ra! Vui lòng thử lại.');
            }
        });
    }

    function huyYeuCauHuy() {
        if (confirm('Bạn có chắc muốn hủy yêu cầu hủy đơn hàng này?')) {
            $.ajax({
                url: '@Url.Action("HuyYeuCauHuyDonHang", "Home")',
                type: 'POST',
                data: {
                    maDonHang: @don.MaDonHang
                },
                success: function(response) {
                    if (response.success) {
                        alert(response.message);
                        location.reload();
                    } else {
                        alert(response.message);
                    }
                },
                error: function() {
                    alert('Có lỗi xảy ra! Vui lòng thử lại.');
                }
            });
        }
    }
</script>

@Html.AntiForgeryToken()