@model Nhom06_QuanLyBanSah.Models.TAIKHOAN
@{
    ViewBag.Title = "Đăng ký tài khoản";
    Layout = "~/Views/Shared/_LayoutPage1.cshtml";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white">
                    <h3 class="text-center mb-0 py-2">
                        <i class="fas fa-user-plus me-2"></i>ĐĂNG KÝ TÀI KHOẢN
                    </h3>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-circle me-2"></i>
                            <strong>Lỗi!</strong> @ViewBag.Error
                        </div>
                    }

                    @using (Html.BeginForm("DangKy", "TaiKhoan", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-user me-1"></i>Họ và tên <span class="text-danger">*</span>
                                </label>
                                @Html.TextBoxFor(m => m.HoTen, new
                                {
                                    @class = "form-control",
                                    placeholder = "Nhập họ và tên...",
                                    required = "required"
                                })
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-envelope me-1"></i>Email <span class="text-danger">*</span>
                                </label>
                                @Html.TextBoxFor(m => m.Email, new
                                {
                                    @class = "form-control",
                                    type = "email",
                                    placeholder = "Nhập email...",
                                    required = "required"
                                })
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-lock me-1"></i>Mật khẩu <span class="text-danger">*</span>
                                </label>
                                @Html.PasswordFor(m => m.MatKhau, new
                                {
                                    @class = "form-control",
                                    placeholder = "Nhập mật khẩu (tối thiểu 6 ký tự)...",
                                    required = "required"
                                })
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-phone me-1"></i>Số điện thoại <span class="text-danger">*</span>
                                </label>
                                @Html.TextBoxFor(m => m.DienThoai, new
                                {
                                    @class = "form-control",
                                    placeholder = "VD: 0912345678",
                                    required = "required"
                                })
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-calendar me-1"></i>Ngày sinh <span class="text-danger">*</span>
                                </label>
                                @Html.TextBoxFor(m => m.NgaySinh, "{0:yyyy-MM-dd}", new
                                {
                                    @class = "form-control",
                                    type = "date",
                                    required = "required"
                                })
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">
                                    <i class="fas fa-venus-mars me-1"></i>Giới tính <span class="text-danger">*</span>
                                </label>
                                <select name="GioiTinh" class="form-control" required>
                                    <option value="">-- Chọn giới tính --</option>
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-map-marker-alt me-1"></i>Địa chỉ <span class="text-danger">*</span>
                            </label>
                            @Html.TextAreaFor(m => m.DiaChi, new
                            {
                                @class = "form-control",
                                rows = 3,
                                placeholder = "Nhập địa chỉ đầy đủ...",
                                required = "required"
                            })
                        </div>

                        <div class="d-grid mb-3">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-user-plus me-2"></i>Đăng Ký
                            </button>
                        </div>

                        <div class="text-center">
                            <p class="mb-0">
                                Đã có tài khoản?
                                <a href="@Url.Action("DangNhap", "TaiKhoan")" class="fw-bold">Đăng nhập ngay</a>
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border-radius: 15px;
    }

    .card-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .btn-lg {
        padding: 12px;
        font-weight: 600;
    }
</style>