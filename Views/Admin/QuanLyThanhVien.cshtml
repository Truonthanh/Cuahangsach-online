@{
    ViewBag.Title = "Quản Lý Thành Viên";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid">
    <h2 class="mb-4 text-primary fw-bold">
        <i class="fas fa-user-friends me-2"></i>Quản Lý Thành Viên
    </h2>

    <!-- Bộ lọc -->
    <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Bộ Lọc</h5>
        </div>
        <div class="card-body">
            <form method="get" action="@Url.Action("QuanLyThanhVien", "Admin")">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Từ ngày</label>
                        <input type="date" name="tuNgay" class="form-control" value="@ViewBag.TuNgay">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Đến ngày</label>
                        <input type="date" name="denNgay" class="form-control" value="@ViewBag.DenNgay">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Hạng thành viên</label>
                        <select name="hang" class="form-select">
                            <option value="">Tất cả</option>
                            <option value="Vàng" @(ViewBag.HangSelected == "Vàng" ? "selected" : "")>Vàng</option>
                            <option value="Bạc" @(ViewBag.HangSelected == "Bạc" ? "selected" : "")>Bạc</option>
                            <option value="Đồng" @(ViewBag.HangSelected == "Đồng" ? "selected" : "")>Đồng</option>
                        </select>
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-search me-2"></i>Lọc
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Bảng thành viên -->
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="fas fa-list me-2"></i>Danh Sách Thành Viên</h5>
        </div>
        <div class="card-body">
            @if (ViewBag.ThanhVienList != null && ViewBag.ThanhVienList.Count > 0)
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Họ Tên</th>
                                <th>Email</th>
                                <th>Điện Thoại</th>
                                <th>Ngày Đăng Ký</th>
                                <th>Hạng Thành Viên</th>
                                <th>Số Đơn Hàng</th>
                                <th>Tổng Chi Tiêu</th>
                                <th>Thao Tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewBag.ThanhVienList)
                            {
                                <tr>
                                    <td>@item.TaiKhoan.userID</td>
                                    <td>@item.TaiKhoan.HoTen</td>
                                    <td>@item.TaiKhoan.Email</td>
                                    <td>@item.TaiKhoan.DienThoai</td>
                                    <td>@item.TaiKhoan.NgayTao.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @if (item.HangThanhVien == "Vàng")
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="fas fa-crown"></i> Vàng
                                            </span>
                                        }
                                        else if (item.HangThanhVien == "Bạc")
                                        {
                                            <span class="badge bg-secondary">
                                                <i class="fas fa-medal"></i> Bạc
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info">
                                                <i class="fas fa-star"></i> Đồng
                                            </span>
                                        }
                                    </td>
                                    <td>@item.SoDonHang</td>
                                    <td>@String.Format("{0:N0} VNĐ", item.TongDonHang)</td>
                                    <td>
                                        <a href="@Url.Action("ChiTietTaiKhoan", "Admin", new { id = item.TaiKhoan.userID })"
                                           class="btn btn-sm btn-info">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="fas fa-info-circle me-2"></i>Không có thành viên nào!
                </div>
            }
        </div>
    </div>
</div>