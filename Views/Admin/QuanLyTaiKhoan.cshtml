@model List<Nhom06_QuanLyBanSah.Models.TAIKHOAN>

@{
    ViewBag.Title = "Quản Lý Tài Khoản";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold mb-0">
            <i class="fas fa-users-cog me-2"></i>Quản Lý Tài Khoản
        </h2>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="fas fa-exclamation-circle me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Thống kê -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h6>Tổng Tài Khoản</h6>
                    <h3 class="mb-0">@Model.Count()</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <h6>Quản Trị Viên</h6>
                    <h3 class="mb-0">@Model.Count(x => x.Role.Equals("admin", StringComparison.OrdinalIgnoreCase))</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h6>Người Dùng</h6>
                    <h3 class="mb-0">@Model.Count(x => x.Role.Equals("user", StringComparison.OrdinalIgnoreCase))</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Bảng danh sách -->
    <div class="card shadow-sm">
        <div class="card-header bg-white">
            <h5 class="mb-0 text-primary">Danh Sách Tài Khoản</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>ID</th>
                            <th>Họ Tên</th>
                            <th>Email</th>
                            <th>Điện Thoại</th>
                            <th>Giới Tính</th>
                            <th>Role</th>
                            <th>Ngày Tạo</th>
                            <th class="text-center">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var tk in Model)
                            {
                                <tr>
                                    <td>@tk.userID</td>
                                    <td>
                                        <strong>@tk.HoTen</strong>
                                    </td>
                                    <td>@tk.Email</td>
                                    <td>@tk.DienThoai</td>
                                    <td>@tk.GioiTinh</td>
                                    <td>
                                        @if (tk.Role != null && tk.Role.Equals("admin", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span class="badge bg-danger">Admin</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-primary">User</span>
                                        }
                                    </td>
                                    <td>@tk.NgayTao</td>
                                    <td class="text-center">
                                        <a href="@Url.Action("ChiTietTaiKhoan", "Admin", new { id = tk.userID })"
                                           class="btn btn-sm btn-info" title="Xem chi tiết">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a href="@Url.Action("SuaTaiKhoan", "Admin", new { id = tk.userID })"
                                           class="btn btn-sm btn-warning" title="Sửa">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        @if (Session["UserID"] != null && (int)Session["UserID"] != tk.userID)
                                        {
                                            <button onclick="confirmDelete(@tk.userID, '@tk.HoTen')"
                                                    class="btn btn-sm btn-danger" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-4">
                                    <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
                                    Không có tài khoản nào
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Form ẩn để xóa -->
<form id="deleteForm" method="post" action="@Url.Action("XoaTaiKhoan", "Admin")" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteId" />
</form>

<script>
    function confirmDelete(id, name) {
        if (confirm('Bạn có chắc chắn muốn xóa tài khoản "' + name + '" không?\n\nLưu ý: Không thể xóa tài khoản đã có đơn hàng!')) {
            document.getElementById('deleteId').value = id;
            document.getElementById('deleteForm').submit();
        }
    }
</script>